#!/bin/bash

FRAME_DIR=$(realpath "$1")
DELAY="${2:-0.033}"

echo "Pre-loading 1,088 frames into RAM..."
mapfile -t FRAMES < <(find "$FRAME_DIR" -maxdepth 1 -name "frame-*.png" | sort -V)
cat "${FRAMES[@]}" > /dev/null

echo "Starting high-speed frame-locked engine..."
TOTAL_FRAMES=${#FRAMES[@]}
I=0

# Convert delay (seconds) into microseconds (e.g., 0.033 -> 33000)
DELAY_US=$(awk "BEGIN {print int($DELAY * 1000000)}")

# Get current time in microseconds by stripping the decimal point
get_time_us() {
    local t=$EPOCHREALTIME
    echo "${t/./}"
}

NEXT=$(get_time_us)

while true; do
    # 1. Update the background instantly
    xwallpaper --zoom "${FRAMES[$I]}"
    
    # 2. Advance index
    I=$(( (I + 1) % TOTAL_FRAMES ))
    
    # 3. Schedule target microsecond timestamp
    NEXT=$(( NEXT + DELAY_US ))
    
    # 4. Pure integer math wait loop (Lightning fast, no awk overhead)
    while true; do
        CURRENT=$(get_time_us)
        [ "$CURRENT" -ge "$NEXT" ] && break
    done
done
